<?xml version="1.0" encoding="utf-8"?>
<!-- api_partner_views.xml — Views for nbhc.api.partner
     Includes:
       - Form view    : full partner detail + status bar + action buttons
       - List view    : sortable summary table
       - Kanban view  : partners grouped by type (dashboard card per partner)
       - Graph view   : API calls this month (bar chart by partner type)
       - Pivot view   : monthly_calls pivot for ad-hoc analysis
       - Search view  : filters + group-by helpers
       - Action       : window action wiring
       - Menu items   : top-level "API Partners" menu
-->
<odoo>

    <!-- ── Form view ───────────────────────────────────────────────────────── -->

    <record id="view_nbhc_api_partner_form" model="ir.ui.view">
        <field name="name">nbhc.api.partner.form</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <form string="API Partner">

                <!-- Status bar -->
                <header>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="oe_highlight"
                            invisible="status != 'pending'"/>
                    <button name="action_suspend"
                            string="Suspend"
                            type="object"
                            invisible="status not in ('approved',)"/>
                    <button name="action_revoke"
                            string="Revoke"
                            type="object"
                            invisible="status == 'revoked'"/>
                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="pending,approved,suspended,revoked"/>
                </header>

                <sheet>

                    <!-- Title block -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Partner Name"/>
                        </h1>
                        <label for="organization"/>
                        <h2>
                            <field name="organization" placeholder="Organisation"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Identity">
                            <field name="partner_type"/>
                            <field name="email" widget="email"/>
                            <field name="odoo_partner_id"/>
                        </group>
                        <group string="Technical">
                            <field name="fhir_version"/>
                            <field name="rate_limit_tier"/>
                            <field name="country_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                    <!-- Tabs -->
                    <notebook>

                        <page string="API Key" name="api_key">
                            <group>
                                <field name="x_nbhc_partner_id" readonly="1"/>
                                <field name="api_key_hash" readonly="1"/>
                                <field name="key_issued_at" readonly="1"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <strong>Security note:</strong>
                                The raw API key is generated by the Go api-gateway and is
                                <em>never</em> stored in Odoo. Only the SHA3-256 hash is
                                displayed above — it is safe to share for audit purposes.
                            </div>
                        </page>

                        <page string="DSA" name="dsa">
                            <group>
                                <field name="dsa_signed"/>
                                <field name="dsa_signed_date"
                                       invisible="not dsa_signed"/>
                                <field name="dsa_expiry"/>
                                <field name="dsa_days_remaining"
                                       decoration-danger="dsa_days_remaining &lt; 7"
                                       decoration-warning="dsa_days_remaining &lt; 30"
                                       widget="integer"/>
                            </group>
                        </page>

                        <page string="Billing" name="billing">
                            <group>
                                <field name="revenue_model"/>
                                <field name="monthly_calls"/>
                                <field name="last_sync_month" readonly="1"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

                <!-- Chatter (Odoo 19 shorthand) -->
                <chatter/>

            </form>
        </field>
    </record>

    <!-- ── List view ──────────────────────────────────────────────────────── -->

    <record id="view_nbhc_api_partner_list" model="ir.ui.view">
        <field name="name">nbhc.api.partner.list</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <list string="API Partners"
                  decoration-danger="status == 'revoked'"
                  decoration-warning="status == 'suspended'"
                  decoration-success="status == 'approved'">
                <field name="name"/>
                <field name="organization"/>
                <field name="partner_type"/>
                <field name="fhir_version"/>
                <field name="rate_limit_tier"/>
                <field name="dsa_expiry"/>
                <field name="dsa_days_remaining"
                       decoration-danger="dsa_days_remaining &lt; 7"
                       decoration-warning="dsa_days_remaining &lt; 30"/>
                <field name="monthly_calls"/>
                <field name="revenue_model"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'approved'"
                       decoration-warning="status == 'suspended'"
                       decoration-danger="status == 'revoked'"
                       decoration-info="status == 'pending'"/>
            </list>
        </field>
    </record>

    <!-- ── Kanban view (grouped by partner_type by default) ───────────────── -->

    <record id="view_nbhc_api_partner_kanban" model="ir.ui.view">
        <field name="name">nbhc.api.partner.kanban</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <kanban default_group_by="partner_type"
                    class="o_kanban_small_column">
                <field name="name"/>
                <field name="organization"/>
                <field name="partner_type"/>
                <field name="status"/>
                <field name="monthly_calls"/>
                <field name="dsa_days_remaining"/>
                <field name="rate_limit_tier"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="organization"/>
                                </div>
                                <div class="mt-2">
                                    <span class="badge rounded-pill"
                                          t-attf-class="#{record.status.rawValue == 'approved' ? 'bg-success' :
                                                          record.status.rawValue == 'suspended' ? 'bg-warning' :
                                                          record.status.rawValue == 'revoked'   ? 'bg-danger'  : 'bg-info'}">
                                        <field name="status"/>
                                    </span>
                                    <span class="ms-2 text-muted">
                                        <field name="rate_limit_tier"/>
                                    </span>
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-phone-square me-1"/>
                                    <span>
                                        <field name="monthly_calls" widget="integer"/> calls/mo
                                    </span>
                                </div>
                                <t t-if="record.dsa_days_remaining.value != 0">
                                    <div t-attf-class="mt-1 #{record.dsa_days_remaining.value &lt; 7 ? 'text-danger' :
                                                              record.dsa_days_remaining.value &lt; 30 ? 'text-warning' : 'text-muted'}">
                                        <i class="fa fa-calendar me-1"/>
                                        DSA: <field name="dsa_days_remaining"/> days
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Graph view — API calls this month, grouped by partner type ─────── -->

    <record id="view_nbhc_api_partner_graph" model="ir.ui.view">
        <field name="name">nbhc.api.partner.graph</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <graph string="API Calls This Month"
                   type="bar"
                   stacked="0">
                <field name="partner_type" type="row"/>
                <field name="monthly_calls" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ── Pivot view ─────────────────────────────────────────────────────── -->

    <record id="view_nbhc_api_partner_pivot" model="ir.ui.view">
        <field name="name">nbhc.api.partner.pivot</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <pivot string="API Usage Pivot">
                <field name="partner_type" type="row"/>
                <field name="revenue_model" type="col"/>
                <field name="monthly_calls" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ── Activity view ──────────────────────────────────────────────────── -->

    <record id="view_nbhc_api_partner_activity" model="ir.ui.view">
        <field name="name">nbhc.api.partner.activity</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <activity string="API Partner Activities">
                <field name="name"/>
                <field name="partner_type"/>
            </activity>
        </field>
    </record>

    <!-- ── Search view ────────────────────────────────────────────────────── -->

    <record id="view_nbhc_api_partner_search" model="ir.ui.view">
        <field name="name">nbhc.api.partner.search</field>
        <field name="model">nbhc.api.partner</field>
        <field name="arch" type="xml">
            <search string="Search API Partners">
                <field name="name" string="Partner"/>
                <field name="organization"/>
                <field name="api_key_hash" string="Key Hash"/>
                <field name="x_nbhc_partner_id" string="UUID"/>

                <!-- Quick filters -->
                <filter name="filter_approved"
                        string="Approved"
                        domain="[('status','=','approved')]"/>
                <filter name="filter_pending"
                        string="Pending Review"
                        domain="[('status','=','pending')]"/>
                <filter name="filter_suspended"
                        string="Suspended"
                        domain="[('status','=','suspended')]"/>
                <filter name="filter_dsa_expiring"
                        string="DSA Expiring (≤30 days)"
                        domain="[('dsa_expiry','&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d')),
                                 ('dsa_expiry','&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_dsa_signed"
                        string="DSA Signed"
                        domain="[('dsa_signed','=',True)]"/>
                <filter name="filter_billable"
                        string="Billable (calls &gt; 0)"
                        domain="[('monthly_calls','&gt;',0),
                                 ('revenue_model','in',['per_call','tiered'])]"/>

                <separator/>

                <!-- Group by -->
                <group expand="0" string="Group By">
                    <filter name="group_type"
                            string="Partner Type"
                            context="{'group_by': 'partner_type'}"/>
                    <filter name="group_status"
                            string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_tier"
                            string="Rate Limit Tier"
                            context="{'group_by': 'rate_limit_tier'}"/>
                    <filter name="group_revenue"
                            string="Revenue Model"
                            context="{'group_by': 'revenue_model'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Window action ──────────────────────────────────────────────────── -->

    <record id="action_nbhc_api_partner" model="ir.actions.act_window">
        <field name="name">API Partners</field>
        <field name="res_model">nbhc.api.partner</field>
        <field name="view_mode">list,kanban,form,graph,pivot,activity</field>
        <field name="search_view_id" ref="view_nbhc_api_partner_search"/>
        <field name="context">{'search_default_filter_approved': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No API Partners registered yet
            </p>
            <p>
                API partners are registered and approved via the NoBorders Healthcare
                api-gateway. Once approved, the partner's SHA3-256 key hash and
                usage metadata are synced here automatically.
            </p>
        </field>
    </record>

    <!-- ── Menu items ─────────────────────────────────────────────────────── -->

    <menuitem id="menu_nbhc_root"
              name="NoBorders API"
              sequence="90"
              web_icon="noborders_api_partners,static/description/icon.png"/>

    <menuitem id="menu_nbhc_api_partners"
              name="API Partners"
              parent="menu_nbhc_root"
              action="action_nbhc_api_partner"
              sequence="10"/>

</odoo>
